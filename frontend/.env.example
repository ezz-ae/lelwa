# ── Lelwa backend (FastAPI / main.py) base URL ───────────────────────────────
# Server-side route handlers (app/api/**) prefer LELWA_API_BASE_URL.
# The browser (client components) uses NEXT_PUBLIC_API_BASE_URL.
# In production set BOTH to your deployed backend URL, e.g. https://lelwa-api.onrender.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
LELWA_API_BASE_URL=http://localhost:8000
