# This Vercel project builds ONLY the Next.js app in frontend/ (see vercel.json).
# The @vercel/next builder already ignores everything outside frontend/, so this
# file just trims the upload. Patterns are gitignore-style; keep them scoped so
# they never match assets inside frontend/.

# Python backend (deployed separately via Dockerfile / Procfile / render.yaml)
/venv
/__pycache__
/main.py
/channels.py
/security.py
/tools.py
/smoke.ts
/requirements.txt
/schema.sql
/render.yaml
/Dockerfile
/.dockerignore
/Procfile

# Separate marketing site (its own deploy)
/marketing

# Local data / scratch
/static
/scripts
/.mypy_cache
/.tmp
/backend.log
